REDIS_URL=redis://127.0.0.1:6379
WS_PORT=9001

SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# At least 16 characters in production
JWT_SECRET=dev-only-change-me-16+
# Short-lived access JWT (WebSocket + PATCH /profile). Refresh with POST /auth/refresh
JWT_ACCESS_EXPIRES_IN=24h
# Legacy: if JWT_ACCESS_EXPIRES_IN unset, JWT_EXPIRES_IN is used as fallback in env parse
# JWT_EXPIRES_IN=7d
# Opaque refresh token TTL in Redis (no wallet re-sign until this lapses)
REFRESH_TOKEN_TTL_DAYS=90

AUTH_CHALLENGE_TTL_SEC=300
# Local only: allow WebSocket ?userId= without JWT
AUTH_DEV_BYPASS=false

# User action audit: hot path = Redis LIST RPUSH; worker batches to Supabase
USER_ACTIONS_BATCH_SIZE=200
USER_ACTIONS_POLL_MS=200
USER_ACTIONS_MAX_LINE_BYTES=65536
